#creating a list of marks of 5 subs 
marks= c(85, 90, 78, 100, 88)
print(marks)

#checking the length of the list
length(marks)

#accessing marks by position #(start from 1)
marks[1]

#checking datatype
class(marks)

#check vector summary 
summary(marks)

#sum command 
print(sum(marks))

#sum in a nice way
total_marks= sum(marks)
print(paste("total marks = ", total_marks))

